# Required: HuggingFace token for LLaMA 3.2 (gated model)
# Get yours at https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Optional: Only needed if you want workers to upload results to S3 directly
# (alternative: pass upload_url in each request with a presigned PUT URL)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=
